<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Account Search</title>
  <link rel="icon" href="/favicon.ico?v=2" type="image/x-icon">
<link rel="shortcut icon" href="/favicon.ico?v=2" type="image/x-icon">
  <style>
    body {
      font-family: "Segoe UI", Roboto, Arial, sans-serif;
      margin: 0;
      padding: 0;
      background: linear-gradient(135deg, #004080, #00bcd4);
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .container {
      background: rgba(255, 255, 255, 0.95);
      padding: 45px 35px;
      border-radius: 20px;
      box-shadow: 0 12px 30px rgba(0,0,0,0.25);
      width: 380px;
      text-align: center;
      backdrop-filter: blur(10px);
      transition: all 0.4s ease;
    }
    .container:hover {
      transform: translateY(-5px) scale(1.02);
      box-shadow: 0 18px 40px rgba(0,0,0,0.3);
    }

    h2 {
      margin-bottom: 30px;
      color: #004080;
      font-size: 26px;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    input {
      padding: 12px;
      font-size: 16px;
      width: 85%;
      border-radius: 10px;
      border: 1px solid #ccc;
      margin-bottom: 20px;
      transition: 0.3s;
    }
    input:focus {
      border-color: #0066cc;
      box-shadow: 0 0 10px rgba(0,102,204,0.3);
      outline: none;
    }

    button {
      padding: 12px 32px;
      background: linear-gradient(135deg, #004080, #007bff);
      color: #fff;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 600;
      font-size: 16px;
      transition: all 0.3s ease;
      box-shadow: 0 6px 15px rgba(0,0,0,0.2);
    }
    button:hover {
      background: linear-gradient(135deg, #0059b3, #0099ff);
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.25);
    }

    /* Loader overlay */
    .loader-overlay {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(0,0,0,0.65);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 1000;
      animation: fadeIn 0.3s ease-in;
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    /* 3D spinning cube loader */
    .cube {
      width: 60px;
      height: 60px;
      position: relative;
      transform-style: preserve-3d;
      animation: spinCube 2s infinite linear;
    }
    .cube div {
      position: absolute;
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, #00bcd4, #004080);
      opacity: 0.9;
      border: 2px solid #fff;
      box-shadow: 0 0 15px rgba(0,188,212,0.7);
    }
    .front  { transform: translateZ(30px); }
    .back   { transform: rotateY(180deg) translateZ(30px); }
    .right  { transform: rotateY(90deg) translateZ(30px); }
    .left   { transform: rotateY(-90deg) translateZ(30px); }
    .top    { transform: rotateX(90deg) translateZ(30px); }
    .bottom { transform: rotateX(-90deg) translateZ(30px); }

    @keyframes spinCube {
      from { transform: rotateX(0deg) rotateY(0deg); }
      to   { transform: rotateX(360deg) rotateY(360deg); }
    }
  </style>
</head>
<body>
  <div class="container">
    <h2>🔍 Search Account Ledger</h2>
    <form id="searchForm" action="/search" method="POST">
      <input type="text" name="accountNumber" placeholder="Enter Account Number" required>
      <br>
      <button type="submit">Search</button>
    </form>
  </div>

  <!-- Loader overlay -->
  <div class="loader-overlay" id="loader">
    <div class="cube">
      <div class="front"></div>
      <div class="back"></div>
      <div class="right"></div>
      <div class="left"></div>
      <div class="top"></div>
      <div class="bottom"></div>
    </div>
  </div>

  <script>
    const form = document.getElementById("searchForm");
    const loader = document.getElementById("loader");

    form.addEventListener("submit", () => {
      loader.style.display = "flex";
    });
  </script>
</body>
</html>
