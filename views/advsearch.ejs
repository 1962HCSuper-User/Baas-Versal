<% if (data && data.length > 0) { %>
  <% const uniqueMembers = [...new Set(data.map(item => item.MMBRNO))]; %>
  <% uniqueMembers.forEach(mmbrno => { %>
    <div style="text-align:center;">
      <button class="download-btn" onclick="handleDownload('<%= mmbrno %>')">
        ✅ Verify The User <%= mmbrno %>
      </button>
    </div>
  <% }); %>
<% } %>

<script>
function handleDownload(mmbrno) {
  // Trigger file download using hidden iframe
  const iframe = document.createElement("iframe");
  iframe.style.display = "none";
  iframe.src = "/verifyUser/" + mmbrno;
  document.body.appendChild(iframe);

  // After small delay (to ensure download starts), redirect to /Verify
  setTimeout(() => {
    window.location.href = "/Verify";
  }, 2000); // 2 seconds delay (adjust if needed)
}
</script>



        <% } else if (data) { %>
          <p>⚠️ No records found.</p>
          <% } %>
</body>

</html>