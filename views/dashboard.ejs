<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container-fluid">
    <div class="row">
      <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
          <span class="navbar-brand mb-0 h1">Node.js Admin Dashboard</span>
        </div>
      </nav>
    </div>

    <div class="row mt-4">
      <!-- Metrics Cards -->
      <div class="col-md-2">
        <div class="card text-white bg-primary mb-3">
          <div class="card-header">CPU Load</div>
          <div class="card-body">
            <h5 class="card-title" id="cpuLoad"><%= metrics.cpuLoad.toFixed(1) %>%</h5>
          </div>
        </div>
      </div>
      <div class="col-md-2">
        <div class="card text-white bg-info mb-3">
          <div class="card-header">Memory Usage</div>
          <div class="card-body">
            <h5 class="card-title" id="memoryUsage"><%= metrics.heapUsedPercent.toFixed(1) %>%</h5>
            <p class="card-text small"><%= metrics.memoryBreakdown.heapUsed %> / <%= metrics.memoryBreakdown.heapTotal %></p>
          </div>
        </div>
      </div>
      <div class="col-md-2">
        <div class="card text-white bg-success mb-3">
          <div class="card-header">Throughput</div>
          <div class="card-body">
            <h5 class="card-title" id="throughput"><%= metrics.throughput %> req/min</h5>
          </div>
        </div>
      </div>
      <div class="col-md-2">
        <div class="card text-white bg-warning mb-3">
          <div class="card-header">Avg Response Time</div>
          <div class="card-body">
            <h5 class="card-title" id="responseTime"><%= metrics.avgResponseTime.toFixed(0) %>ms</h5>
          </div>
        </div>
      </div>
      <div class="col-md-2">
        <div class="card text-white <%= metrics.estimatedConcurrent > 30 ? 'bg-success' : metrics.estimatedConcurrent > 10 ? 'bg-warning' : 'bg-danger' %> mb-3">
          <div class="card-header">Est. Concurrent Capacity</div>
          <div class="card-body">
            <h5 class="card-title" id="capacity">~<%= metrics.estimatedConcurrent %></h5>
            <p class="card-text small">Can handle more</p>
          </div>
        </div>
      </div>
      <div class="col-md-2">
        <div class="card text-white bg-secondary mb-3">
          <div class="card-header">Connected IPs</div>
          <div class="card-body">
            <h5 class="card-title" id="ipCount"><%= metrics.connectedIPs.length %></h5>
          </div>
        </div>
      </div>
    </div>

    <div class="row mt-4">
      <!-- Charts Row -->
      <div class="col-md-6">
        <div class="card">
          <div class="card-header">Memory Breakdown (Doughnut)</div>
          <div class="card-body">
            <canvas id="memoryChart"></canvas>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card">
          <div class="card-header">CPU Cores Load (Doughnut)</div>
          <div class="card-body">
            <canvas id="cpuChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <div class="row mt-4">
      <!-- Connected IPs -->
      <div class="col-md-4">
        <div class="card">
          <div class="card-header">Connected IPs (<span id="liveIpCount"><%= metrics.connectedIPs.length %></span>)</div>
          <div class="card-body">
            <ul class="list-group" id="ipList" style="max-height: 200px; overflow-y: auto;">
              <% metrics.connectedIPs.forEach(({ip, ts}) => { %>
                <li class="list-group-item d-flex justify-content-between">
                  <span><%= ip %></span>
                  <small class="text-muted"><%= ts %></small>
                </li>
              <% }); %>
            </ul>
          </div>
        </div>
      </div>

      <!-- Alerts -->
      <div class="col-md-4">
        <div class="card">
          <div class="card-header">Critical Alerts <button class="btn btn-sm btn-outline-danger float-end" onclick="clearAlerts()">Clear</button></div>
          <div class="card-body">
            <div id="alertsList">
              <% if (metrics.alerts.length > 0) { %>
                <% metrics.alerts.forEach(alert => { %>
                  <div class="alert alert-danger" role="alert"><%= alert %></div>
                <% }); %>
              <% } else { %>
                <p class="text-success">All systems nominal.</p>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Server Info -->
      <div class="col-md-4">
        <div class="card">
          <div class="card-header">Server Info</div>
          <div class="card-body">
            <p><strong>Node:</strong> <%= metrics.serverInfo.nodeVersion %></p>
            <p><strong>OS:</strong> <%= metrics.serverInfo.platform %></p>
            <p><strong>Total Mem:</strong> <%= metrics.serverInfo.totalMemory %></p>
            <p><strong>PID:</strong> <%= metrics.serverInfo.pid %></p>
          </div>
        </div>
      </div>
    </div>

    <div class="row mt-4">
      <!-- Performance Line Chart -->
      <div class="col-md-8">
        <div class="card">
          <div class="card-header">Performance Overview (Last 20 Updates)</div>
          <div class="card-body">
            <canvas id="metricsChart"></canvas>
          </div>
        </div>
      </div>
      <!-- Logs -->
      <div class="col-md-4">
        <div class="card">
          <div class="card-header">Recent Logs</div>
          <div class="card-body">
            <ul class="list-group" id="logsList" style="max-height: 300px; overflow-y: auto;">
              <% metrics.logs.forEach(log => { %>
                <li class="list-group-item">
                  <span class="badge <%= log.type === 'warn' ? 'bg-warning' : 'bg-info' %>"><%= log.type.toUpperCase() %></span>
                  <%= log.message %> <small class="text-muted"><%= log.formattedTime %></small>
                </li>
              <% }); %>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Uptime and Total Requests -->
    <div class="row mt-4">
      <div class="col-md-6">
        <div class="card">
          <div class="card-header">Uptime</div>
          <div class="card-body">
            <p><%= metrics.uptime %></p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card">
          <div class="card-header">Total Requests Handled</div>
          <div class="card-body">
            <p><%= metrics.totalRequests %></p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.socket.io/4.7.4/socket.io.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  <script src="/script.js"></script>
</body>
</html>