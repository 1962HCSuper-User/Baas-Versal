<!DOCTYPE html>
<html>
<head>
  <title>ACCMAST Fetch</title>
  <link rel="icon" href="/favicon.ico?v=2" type="image/x-icon">
<link rel="shortcut icon" href="/favicon.ico?v=2" type="image/x-icon">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="container p-4">
  <h1 class="mb-4">ACCMAST Fetch & Save</h1>

  <% if (message) { %>
    <div class="alert alert-warning"><%= message %></div>
  <% } %>

  <!-- Step 1: Input form -->
  <form method="POST" action="/accmast/fetch" class="mb-4">
    <div class="mb-3">
      <label class="form-label">Enter Account No:</label>
      <input type="text" name="accnumber" value="<%= accnumber %>" class="form-control" required>
    </div>
    <button type="submit" class="btn btn-primary">Fetch Data</button>
  </form>

  <!-- Step 2: Show fetched row -->
  <% if (row) { %>
    <h3>Fetched Data</h3>
    <form method="POST" action="/accmast/confirm">
      <% for (let key in row) { %>
        <div class="mb-2">
          <label class="form-label"><%= key %></label>
          <input type="text" name="<%= key %>" value="<%= row[key] %>" class="form-control" readonly>
        </div>
      <% } %>
      <button type="submit" class="btn btn-success">Confirm & Save</button>
    </form>
  <% } %>
</body>
</html>
